[Unit]
Description=FinanceQA Feishu active scan
Documentation=file:%h/finance_qa/README.md
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=root
Group=root
WorkingDirectory=%h/finance_qa
Environment=FINANCEQA_ENV_FILE=%h/finance_qa/.env
ExecStart=%h/finance_qa/bin/financeqa feishu scan
TimeoutStartSec=20min
Nice=5
IOSchedulingClass=best-effort
IOSchedulingPriority=6
SyslogIdentifier=financeqa-feishu-scan
