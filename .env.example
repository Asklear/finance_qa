# PostgreSQL connection (required in PG-only mode)
PGHOST=pgm-xxxx.pg.rds.aliyuncs.com
PGPORT=5432
PGUSER=financeqa_app
PGPASSWORD=replace_with_strong_password
PGDATABASE=bossagent_app
FINANCEQA_PG_SCHEMA=your_tenant_schema

# Optional full DSN (takes precedence over PG* vars)
# FINANCEQA_PG_DSN=host=... port=5432 user=... password=... dbname=... search_path=your_tenant_schema,public

# Optional defaults
FINANCEQA_DEFAULT_COMPANY=your_company_name
