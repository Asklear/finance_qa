AGENT_PATROL_ENV=production
AGENT_PATROL_LIVE=1
AGENT_PATROL_ROOT=/opt/finance_qa/agent-patrol
AGENT_PATROL_TIMEZONE=Asia/Shanghai
AGENT_PATROL_CONFIG=presets/financeqa-production.yaml
AGENT_PATROL_SUITE=daily
AGENT_PATROL_OUTPUT_DIR=/var/log/agent-patrol/financeqa
AGENT_PATROL_LOG_FILE=/var/log/agent-patrol/financeqa/dry-run.log
AGENT_PATROL_FAIL_ON_THRESHOLD=0
AGENT_PATROL_RUN_DOCTOR=1
AGENT_PATROL_REQUIRE_GOLDEN_REFERENCE=1
AGENT_PATROL_REQUIRE_RESOLVED_ENV=1
AGENT_PATROL_REPORT_RETENTION_DAYS=30

# Source the live FinanceQA read-only database settings for snapshot export.
AGENT_PATROL_FINANCEQA_ENV_FILE=/root/finance_qa/.env
AGENT_PATROL_REFERENCE_EXPORT_CMD=examples/golden/export_financeqa_snapshot.sh
FINANCEQA_SNAPSHOT_OUTPUT=tmp/reference-snapshots/financeqa-production-latest.json.gz
FINANCEQA_REFERENCE_SNAPSHOT=tmp/reference-snapshots/financeqa-production-latest.json.gz
FINANCEQA_GOLDEN_CMD="node examples/golden/financeqa_snapshot_reference.mjs --template {template} --question-file {questionFile} --snapshot ${FINANCEQA_REFERENCE_SNAPSHOT}"

# Direct FinanceQA MCP is diagnostic only; golden reference above decides accuracy.
FINANCEQA_MCP_URL=http://127.0.0.1:3009/mcp
FINANCEQA_MCP_READ_TOKEN_FILE=/root/finance_qa/secrets/mcp_read_token

# OpenClaw actual path. It writes only patrol-* local sessions and sends no IM.
OPENCLAW_AGENT_CMD="node examples/runners/openclaw_local_runner.mjs --question-file {questionFile} --session-id {sessionId} --thinking off --timeout 360"

# Ask an external LLM to vary wording only. The golden answer is not LLM-generated.
AGENT_PATROL_QUESTION_GEN_CMD="node examples/question-generators/llm_command_rewriter.mjs --input {inputFile}"
AGENT_PATROL_LLM_CMD="node examples/question-generators/openai_compatible_chat.mjs"
AGENT_PATROL_LLM_ENV_FILE=tmp/secrets/agent-patrol-llm.env
AGENT_PATROL_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
AGENT_PATROL_LLM_BASE_URL_ENV=DEEPSEEK_BASE_URL
AGENT_PATROL_LLM_MODEL_ENV=DEEPSEEK_MODEL
AGENT_PATROL_LLM_TIMEOUT_MS=120000

# Clean up only the runner this patrol actually uses.
AGENT_PATROL_CLEANUP_CMD=examples/cleanup/run-agent-cleanups.sh
AGENT_PATROL_CLEANUP_KINDS=openclaw
AGENT_PATROL_SESSION_RETENTION_DAYS=2
AGENT_PATROL_OPENCLAW_SESSION_DIR=/root/.openclaw/agents/main/sessions
