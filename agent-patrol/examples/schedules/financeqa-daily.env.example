AGENT_PATROL_LIVE=1
# Use a non-production OpenClaw host. It must have openclaw-finance installed and test data loaded.
AGENT_PATROL_OPENCLAW_HOST=clawdbot
AGENT_PATROL_SUITE=smoke
AGENT_PATROL_OUTPUT_DIR=tmp/financeqa-dry-run
FINANCEQA_MCP_URL=http://127.0.0.1:3009/mcp
FINANCEQA_MCP_READ_TOKEN_FILE=/root/finance_qa/secrets/mcp_read_token
OPENCLAW_AGENT_CMD="node examples/runners/openclaw_ssh_runner.mjs --host ${AGENT_PATROL_OPENCLAW_HOST} --question-file {questionFile} --session-id {sessionId} --thinking off --timeout 360"
