AGENT_PATROL_LIVE=1
AGENT_PATROL_TIMEZONE=Asia/Shanghai
# Install this schedule on a non-production OpenClaw host with openclaw-finance and test data.
AGENT_PATROL_CONFIG=presets/financeqa.yaml
AGENT_PATROL_SUITE=smoke
AGENT_PATROL_OUTPUT_DIR=tmp/financeqa-dry-run
# Keep systemd/cron status about report generation. Business accuracy failures
# are recorded in summary.json and dry-run.log as threshold_failed.
AGENT_PATROL_FAIL_ON_THRESHOLD=0
# Optional: rebuild the local FinanceQA MCP SQLite mirror from the same snapshot
# used by the golden provider before each dry-run. This keeps actual and golden
# on the same data snapshot.
# AGENT_PATROL_PREPARE_CMD=examples/schedules/prepare-financeqa-snapshot-mirror.sh
AGENT_PATROL_CLEANUP_CMD=examples/cleanup/run-agent-cleanups.sh
# Match this to the agent runner(s) used by this patrol job: openclaw, hermes, claude.
# This OpenClaw FinanceQA example only uses the OpenClaw runner.
AGENT_PATROL_CLEANUP_KINDS=openclaw
AGENT_PATROL_SESSION_RETENTION_DAYS=3
AGENT_PATROL_OPENCLAW_SESSION_DIR=/root/.openclaw/agents/main/sessions
AGENT_PATROL_HERMES_SESSION_DIR=/root/.hermes/sessions
AGENT_PATROL_CLAUDE_SESSION_DIR=/root/.claude/sessions
FINANCEQA_MCP_URL=http://127.0.0.1:3009/mcp
FINANCEQA_MCP_READ_TOKEN_FILE=/root/finance_qa/secrets/mcp_read_token
# FINANCEQA_MCP_URL is the direct-tool diagnostic baseline. Configure a real
# structured goldenReference command in the YAML before treating reports as a
# 90% business-accuracy gate.
# Optional LLM question generator command. Enable the questionGenerator block in
# the YAML to use it. The command receives the selected cases as JSON on stdin
# and can also use the {inputFile} placeholder. It must return JSON/JSONL with
# {caseId, template, question}; invalid or unsafe output falls back to the
# template question.
# AGENT_PATROL_QUESTION_GEN_CMD="node examples/question-generators/llm_command_rewriter.mjs --input {inputFile}"
# Recommended: use a direct OpenAI-compatible model call so question generation
# does not create OpenClaw/Hermes/Claude agent sessions.
# AGENT_PATROL_LLM_CMD="node examples/question-generators/openai_compatible_chat.mjs"
# AGENT_PATROL_LLM_ENV_FILE=tmp/secrets/agent-patrol-llm.env
# AGENT_PATROL_LLM_API_KEY_ENV=DEEPSEEK_API_KEY
# AGENT_PATROL_LLM_BASE_URL_ENV=DEEPSEEK_BASE_URL
# AGENT_PATROL_LLM_MODEL_ENV=DEEPSEEK_MODEL
# AGENT_PATROL_LLM_RESPONSE_FORMAT=json_object
# Alternative: point this at any local LLM CLI that reads prompt from stdin.
# AGENT_PATROL_LLM_CMD="your-llm-cli-that-reads-prompt-from-stdin"
# AGENT_PATROL_LLM_TIMEOUT_MS=120000
# Snapshot-backed command for the commented goldenReference block in presets/financeqa.yaml.
# Export it with examples/golden/export_financeqa_snapshot.sh from a read-only RDS env.
FINANCEQA_REFERENCE_SNAPSHOT=tmp/reference-snapshots/financeqa-latest.json.gz
FINANCEQA_SQLITE_MIRROR_OUTPUT=/root/finance_qa/testdata/financeqa_patrol.sqlite
FINANCEQA_SQLITE_MIRROR_BACKUP_DIR=tmp/financeqa-sqlite-backups
FINANCEQA_MCP_SERVICE=financeqa-mcp.service
# FINANCEQA_GOLDEN_CMD="node examples/golden/financeqa_snapshot_reference.mjs --template {template} --question-file {questionFile} --snapshot ${FINANCEQA_REFERENCE_SNAPSHOT}"
# Legacy diagnostic command that canonicalizes the query but still calls finance-query.
# FINANCEQA_GOLDEN_CMD="node examples/golden/financeqa_canonical_golden.mjs --template {template} --question-file {questionFile}"
OPENCLAW_AGENT_CMD="node examples/runners/openclaw_local_runner.mjs --question-file {questionFile} --session-id {sessionId} --thinking off --timeout 360"
