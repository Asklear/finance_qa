AGENT_PATROL_LIVE=1
# Install this schedule on a non-production OpenClaw host with openclaw-finance and test data.
AGENT_PATROL_SUITE=smoke
AGENT_PATROL_OUTPUT_DIR=tmp/financeqa-dry-run
FINANCEQA_MCP_URL=http://127.0.0.1:3009/mcp
FINANCEQA_MCP_READ_TOKEN_FILE=/root/finance_qa/secrets/mcp_read_token
OPENCLAW_AGENT_CMD="node examples/runners/openclaw_local_runner.mjs --question-file {questionFile} --session-id {sessionId} --thinking off --timeout 360"
