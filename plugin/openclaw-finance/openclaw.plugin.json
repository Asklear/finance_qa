{
  "id": "openclaw-finance",
  "version": "2.2.4",
  "channels": [
    "openclaw-finance"
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "transport": {
        "type": "string",
        "enum": [
          "stdio",
          "remote"
        ],
        "description": "FinanceQA MCP transport"
      },
      "mcp_url": {
        "type": "string",
        "description": "Remote FinanceQA MCP URL"
      },
      "mcp_token": {
        "type": "string",
        "description": "Bearer token for remote FinanceQA MCP auth"
      },
      "mcp_token_file": {
        "type": "string",
        "description": "Path to a file containing the remote FinanceQA MCP bearer token"
      },
      "timeout_ms": {
        "type": "number",
        "description": "Remote MCP request timeout in milliseconds"
      }
    }
  }
}
